# ─── Next.js ──────────────────────────────────────────────────────────────────
# Suppresses the "lockfile missing swc dependencies" warning on Node 19.3
NEXT_IGNORE_INCORRECT_LOCKFILE=1

# ─── SMTP Configuration ────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your own values.

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@setes.ie
SMTP_PASS=your_smtp_password_here
# Destination address for quote requests (defaults to SMTP_USER if not set)
SMTP_TO=sales@setes.ie
